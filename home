<!DOCTYPE html>
<html>
    <head>
        <title>
            Nav bar
        </title>
        <style>
            body{
                font-family:fantasy;
                margin:0;
                color:aliceblue;
            }
            .topNav{
                overflow:hidden;
                background-color:black;
                color:aliceblue;
            }
            .topNav a.active{
                background-color: rgb(240, 216, 79);
                color:black;
            }
            .topNav a.hover{
                background-color: antiquewhite;
                color:black;
            }
            .topNav a{
                float:left;
                padding: 14px 16px;
                text-align: center;
                color:#7cb0f5;
                font-size: 17px;
            }
            img{
                height: 500px;
                width: 1160px;
            }
        </style>
    </head>
    <body>
        <div class="topNav">
            <a class="active" href="index.html">
                Home
            </a>
            <a href="about.html">
                About
            </a>
            <a href="gallery.html">
                Gallery
            </a>
            <a href="contact.html">
                Contact-Us
            </a>
        </div>
        <!--Slide Show-->
        <section>
            <img class="mySlides" src="img1.jpg">
            <img class="mySlides" src="img2.avif">
            <img class="mySlides" src="img3.webp">
        </section>
        <script>
            var myIndex = 0;
            carousal();
            
            function carousal(){
                var i;
                var x = document.getElementsByClassName("mySlides");
                for( i = 0; i < x.length; i++) {
                    x[i].style.display = "none";
                }
                myIndex++;
                if(myIndex > x.length) {myIndex = 1}
                x[myIndex-1].style.display = "block";
                setTimeout(carousal,3000);
            }
        </script>
    </body>
</html>
